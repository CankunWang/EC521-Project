<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script<% if (nonce) { %> nonce="<%= nonce %>"<% } %> src="/static/probe.js?route=<%= encodeURIComponent(route) %>"></script>
  </head>
  <body data-lab-route="<%= route %>" data-xss-state="idle">
    <h3>/stored</h3>
    <p id="lab-success-marker">Payload state: idle</p>
    <form method="POST" action="/stored">
      <input name="comment" style="width: 520px" placeholder="Try XSS payload here" />
      <button type="submit">Submit</button>
    </form>
    <ul>
      <% items.forEach(function (item) { %>
        <li><% if (safeHtmlOutput) { %><%= item %><% } else { %><%- item %><% } %></li>
      <% }) %>
    </ul>
    <hr />
    <p><strong>JS Context Sink (last comment)</strong></p>
    <script<% if (nonce) { %> nonce="<%= nonce %>"<% } %>>
      var lastComment = "<%- jsOut %>";
      if (typeof window.__xssLabSignal === "function") {
        try { eval('"use strict"; void lastComment;'); } catch(e) {}
      }
    </script>
    <p>var lastComment = "<%= jsOut %>"</p>
  </body>
</html>
