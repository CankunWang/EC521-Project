<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script<% if (nonce) { %> nonce="<%= nonce %>"<% } %> src="/static/probe.js?route=<%= encodeURIComponent(route) %>"></script>
  </head>
  <body data-lab-route="<%= route %>">
    <h3>/stored</h3>
    <form method="POST" action="/stored">
      <input name="comment" style="width: 520px" placeholder="Try XSS payload here" />
      <button type="submit">Submit</button>
    </form>
    <ul>
      <% items.forEach(function (item) { %>
        <li><% if (safeHtmlOutput) { %><%= item %><% } else { %><%- item %><% } %></li>
      <% }) %>
    </ul>
  </body>
</html>
