<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <script<% if (nonce) { %> nonce="<%= nonce %>"<% } %> src="/static/probe.js?route=<%= encodeURIComponent(route) %>"></script>
  </head>
  <body data-lab-route="<%= route %>" data-xss-state="idle">
    <h3>/reflect</h3>
    <p id="lab-success-marker">Payload state: idle</p>
    <p>Query:</p>
    <div id="out"><% if (safeHtmlOutput) { %><%= source %><% } else { %><%- source %><% } %></div>
    <hr />
    <p><strong>Context Output Preview</strong></p>
    <ul>
      <li>HTML: <code><%= htmlOut %></code></li>
      <li>Attribute: <code><%= attrOut %></code></li>
      <li>JS string: <code><%= jsOut %></code></li>
      <li>URL: <code><%= safeUrl %></code></li>
    </ul>
    <hr />
    <p><strong>JS Context Sink</strong></p>
    <script<% if (nonce) { %> nonce="<%= nonce %>"<% } %>>
      var userInput = "<%- jsOut %>";
      if (typeof window.__xssLabSignal === "function") {
        try { eval('"use strict"; void userInput;'); } catch(e) {}
      }
    </script>
    <p>var userInput = "<%= jsOut %>"</p>
  </body>
</html>
