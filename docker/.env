ENABLE_ALLOWLIST= 1
ENABLE_CONTEXT_ENCODING=
ENABLE_TEMPLATE_AUTO_ESCAPE=
ENABLE_DOM_SANITIZER=
ENABLE_TEXT_RENDER=

# Layer 2 (Browser)
ENABLE_CSP=
CSP_MODE=
ENABLE_DOM_DEFENSE=
ENABLE_TRUSTED_TYPES=
ENABLE_CROSS_ORIGIN_ISOLATION=

# Layer 3 (Session)
ENABLE_ORIGIN_CHECK=
COOKIE_HTTPONLY=
COOKIE_SECURE=
